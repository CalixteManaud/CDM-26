generator client {
  provider            = "prisma-client"
  output              = "./prisma-client"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PARTICIPANT
  GUEST
}

enum MatchStage {
  GROUP
  PLAYOFF // Barrages (meilleurs 3èmes)
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELED
}

model User {
  id       String   @id @default(uuid()) @db.Uuid
  email    String   @unique
  name     String
  username String? // Pseudo pour l'affichage public
  avatar   String? // URL de la photo de profil
  role     UserRole @default(GUEST) // Default to GUEST, can upgrade to PARTICIPANT
  clerkId  String   @unique // Clerk user ID

  // Lien Twitch — requis pour parier (les points sont débités/crédités via Wizebot
  // sur le compte Twitch de l'utilisateur).
  twitchUsername String? @unique // Login Twitch en lowercase, ex: "blaize_viewer42"
  twitchUserId   String? @unique // ID Twitch immuable (résiste aux renommages), fourni par Clerk OAuth

  // Relations
  players      Player[]
  coachedTeams Team[]   @relation("TeamCoach") // Teams where this user is the coach/admin
  bets         Bet[]
  marketBets   MarketBet[] @relation("MarketBetUser")
  betSlips     BetSlip[]   @relation("BetSlipUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([username])
}

model Tournament {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  startDate          DateTime
  teamsPerGroup      Int
  playersPerTeam     Int
  groupCount         Int
  groupStageComplete Boolean  @default(false)

  // Relations
  teams     Team[]
  groups    Group[]
  matches   Match[]
  standings Standing[]

  // Marchés tournoi (top buteur, MVP, vainqueur)
  bettingMarkets BettingMarket[] @relation("TournamentMarkets")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id           String @id @default(uuid()) @db.Uuid
  name         String
  position     Int
  tournamentId String @db.Uuid

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams      Team[]
  matches    Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, position])
  @@index([tournamentId])
}

model Team {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  shortName String
  logo      String?

  disqualified           Boolean @default(false)
  disqualificationReason String? // Raison de la disqualification

  tournamentId String  @db.Uuid
  groupId      String? @db.Uuid
  coachUserId  String? @db.Uuid // Team coach/admin (optional)

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group      Group?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  coach      User?      @relation("TeamCoach", fields: [coachUserId], references: [id], onDelete: SetNull)

  players Player[]

  // Match relations (disambiguation)
  homeMatches   Match[] @relation("HomeTeam")
  awayMatches   Match[] @relation("AwayTeam")
  winnerMatches Match[] @relation("WinnerTeam")

  // Events live (l'équipe concernée par un but/carton)
  matchEvents MatchEvent[] @relation("MatchEventTeam")

  standings Standing[]

  // Paris pointant sur cette équipe (HOME_WIN ou AWAY_WIN)
  betsPickedOn Bet[] @relation("BetPickedTeam")

  // Pools des marchés où cette équipe est l'outcome (vainqueur tournoi par ex.)
  marketPoolEntries MarketPool[] @relation("MarketPoolTeam")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, shortName])
  @@index([tournamentId])
  @@index([groupId])
  @@index([coachUserId])
}

model Player {
  id           String @id @default(uuid()) @db.Uuid
  jerseyNumber Int
  position     String

  userId String @db.Uuid
  teamId String @db.Uuid

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  stats MatchPlayerStats[]

  // Pools des marchés où ce joueur est l'outcome (top buteur, MVP)
  marketPoolEntries MarketPool[] @relation("MarketPoolPlayer")

  // Events live (le joueur qui a marqué / pris un carton)
  matchEvents MatchEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, jerseyNumber])
  @@index([userId])
  @@index([teamId])
}

model Match {
  id        String      @id @default(uuid()) @db.Uuid
  stage     MatchStage
  status    MatchStatus @default(SCHEDULED)
  matchDate DateTime

  homeScore    Int? // null tant que pas joué
  awayScore    Int?
  winnerTeamId String? @db.Uuid

  // Streaming URLs
  twitchUrl   String? // Twitch stream URL
  discordUrl  String? // Discord voice/stream channel
  youtubeUrl  String? // YouTube live stream
  streamTitle String? // Stream title/description

  groupId      String? @db.Uuid
  tournamentId String  @db.Uuid

  homeTeamId String @db.Uuid
  awayTeamId String @db.Uuid

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group      Group?     @relation(fields: [groupId], references: [id], onDelete: SetNull)

  homeTeam   Team  @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam   Team  @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  winnerTeam Team? @relation("WinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)

  playerStats MatchPlayerStats[]

  // Paris 1X2 (pari mutuel via Wizebot)
  bettingPool MatchBettingPool?
  bets        Bet[]

  // Marchés additionnels (score exact, total buts, BTTS…)
  bettingMarkets BettingMarket[] @relation("MatchMarkets")

  // Live events (kick-off, buts, cartons…)
  events MatchEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([groupId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([winnerTeamId])
}

model MatchPlayerStats {
  id String @id @default(uuid()) @db.Uuid

  goals       Int @default(0)
  assists     Int @default(0)
  yellowCards Int @default(0)
  redCards    Int @default(0)

  matchId  String @db.Uuid
  playerId String @db.Uuid

  // Relations
  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
}

model Standing {
  id           String @id @default(uuid()) @db.Uuid
  position     Int
  played       Int    @default(0)
  won          Int    @default(0)
  drawn        Int    @default(0)
  lost         Int    @default(0)
  goalsFor     Int    @default(0)
  goalsAgainst Int    @default(0)
  points       Int    @default(0)

  tournamentId String @db.Uuid
  teamId       String @db.Uuid

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([teamId])
}

enum WebhookEventType {
  MATCH_STARTED // Match passe en LIVE
  MATCH_FINISHED // Match passe en FINISHED
  SCORE_UPDATED // Score du match mis à jour
  STANDINGS_UPDATED // Classement d'une poule/groupe mis à jour
  BRACKET_UPDATED // Bracket mis à jour (progression)
}

model Webhook {
  id       String             @id @default(uuid()) @db.Uuid
  userId   String             @db.Uuid
  name     String // Nom personnalisé du webhook
  url      String // URL du webhook
  secret   String? // Secret pour signer les requêtes (optionnel)
  events   WebhookEventType[] // Types d'événements à écouter
  isActive Boolean            @default(true)

  // Filtres optionnels
  tournamentId String? @db.Uuid // Si défini, ne déclenche que pour ce tournoi
  teamId       String? @db.Uuid // Si défini, ne déclenche que pour cette équipe

  // Statistiques
  lastTriggeredAt DateTime?
  triggerCount    Int       @default(0)
  failureCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tournamentId])
  @@index([teamId])
  @@index([isActive])
}

// =================== PARIS ===================
//
// Système de paris en pari mutuel.
//  - Entrée unique : UI cdm26.com (formulaire de pari).
//  - Monnaie : points de chaîne Twitch gérés par Wizebot — on débite via
//    l'API Wizebot au placement, on crédite à la résolution.
//
// Flow:
//  1. User connecté soumet POST /api/bets/place via le formulaire site.
//  2. API : auth Clerk → check twitchUsername lié → débit Wizebot (points/remove).
//  3. Si débit OK, on crée le Bet (PENDING) et on incrémente le pool concerné
//     dans la transaction Prisma. wizebotDebitTxId stocke l'ID de la transac.
//  4. Frontend recalcule les cotes en direct depuis MatchBettingPool:
//     coteHome = totalPool / totalHomePool * (1 - housePct)
//  5. Settlement à la fin du match :
//     - boucle sur les Bet PENDING
//     - winners reçoivent (pointsWagered / poolGagnant) * (totalPool * (1 - housePct))
//     - on crédite Wizebot (points/add) ; status → WON / LOST / CREDIT_FAILED.
//     - retryFailedCredits() rejoue les CREDIT_FAILED si Wizebot était down.
//
// Verrouillage: pas de flag stocké, dérivé dynamiquement de match.status et
// match.matchDate. Quand le match passe en FINISHED / fenêtre LIVE expirée,
// les paris sont automatiquement bloqués.

enum BetOutcome {
  HOME_WIN
  DRAW
  AWAY_WIN
}

enum BetStatus {
  PENDING // pari pris, match pas encore terminé
  WON // gagné, points crédités côté Wizebot
  LOST // perdu
  VOID // match annulé → mise remboursée
  CANCELED // pari annulé manuellement avant verrouillage
  CREDIT_FAILED // gagné mais le crédit Wizebot a échoué (à rejouer)
}

model MatchBettingPool {
  id      String @id @default(uuid()) @db.Uuid
  matchId String @unique @db.Uuid
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Totaux mis à jour à chaque pari pour calcul des cotes en pari mutuel
  totalHomePool Int @default(0) // Σ pointsWagered des paris HOME_WIN
  totalDrawPool Int @default(0) // Σ pointsWagered des paris DRAW
  totalAwayPool Int @default(0) // Σ pointsWagered des paris AWAY_WIN

  // Compteurs pour stats UI
  betCount      Int @default(0)
  uniqueBettors Int @default(0)

  // Pourcentage retenu par "la maison" (ex: 5%) — 0 = pari mutuel pur
  housePercentage Decimal @default(0) @db.Decimal(5, 2)

  // Snapshot pris au moment du verrouillage (passage LIVE) pour le settlement
  finalTotalPool Int? // null tant que pas verrouillé
  lockedAt       DateTime?
  settledAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bet {
  id String @id @default(uuid()) @db.Uuid

  matchId String @db.Uuid
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Restrict)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  outcome      BetOutcome
  pickedTeamId String?    @db.Uuid // null si DRAW, sinon homeTeam ou awayTeam du match
  pickedTeam   Team?      @relation("BetPickedTeam", fields: [pickedTeamId], references: [id], onDelete: SetNull)

  // ID de la transaction Wizebot pour le DÉBIT au moment du placement.
  wizebotDebitTxId String?

  pointsWagered Int

  // Snapshot informatif des cotes affichées au moment du pari (UX uniquement,
  // le payout réel est recalculé au settlement à partir des pools finaux).
  oddsAtPlacement Decimal @db.Decimal(7, 3)

  status       BetStatus @default(PENDING)
  actualPayout Int       @default(0)
  settledAt    DateTime?

  // Idempotence Wizebot — header X-Wizebot-Event-Id si dispo, sinon hash payload
  wizebotEventId String? @unique

  // Audit du crédit sortant
  wizebotCreditTxId  String? // ID retourné par l'API Wizebot
  wizebotCreditError String? // dernière erreur de crédit pour CREDIT_FAILED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([userId])
  @@index([status])
  @@index([matchId, status])
  @@index([userId, matchId])
}

// =================== MARCHÉS FLEXIBLES ===================
//
// Tables génériques pour gérer plusieurs types de paris au-delà du 1X2 :
//  - Score exact d'un match
//  - Total buts (over/under)
//  - Both teams to score
//  - Top buteur d'un tournoi
//  - MVP d'un tournoi
//  - Vainqueur d'un tournoi
//
// Le 1X2 (HOME/DRAW/AWAY) reste sur Bet/MatchBettingPool pour ne pas casser le
// flow Wizebot existant. Tout le reste utilise BettingMarket + MarketPool +
// MarketBet. Un MarketBet peut être groupé dans un BetSlip pour un pari
// combiné (cote = produit, all-or-nothing).

enum BettingMarketType {
  MATCH_EXACT_SCORE       // outcomeKey = "<home>-<away>"
  MATCH_TOTAL_GOALS       // outcomeKey = "OVER" | "UNDER" ; param = ligne ex "2.5"
  MATCH_BTTS              // outcomeKey = "YES" | "NO"
  TOURNAMENT_TOP_SCORER   // outcomeKey = playerId
  TOURNAMENT_MVP          // outcomeKey = playerId
  TOURNAMENT_WINNER       // outcomeKey = teamId
}

enum BettingMarketStatus {
  OPEN
  LOCKED
  SETTLED
  VOID
}

model BettingMarket {
  id     String              @id @default(uuid()) @db.Uuid
  type   BettingMarketType
  status BettingMarketStatus @default(OPEN)
  param  String? // ex "2.5" pour MATCH_TOTAL_GOALS

  matchId String? @db.Uuid
  match   Match?  @relation("MatchMarkets", fields: [matchId], references: [id], onDelete: Cascade)

  tournamentId String?     @db.Uuid
  tournament   Tournament? @relation("TournamentMarkets", fields: [tournamentId], references: [id], onDelete: Cascade)

  closesAt DateTime // pari fermé après cette date

  housePercentage   Decimal   @default(0) @db.Decimal(5, 2)
  finalTotalPool    Int? // snapshot au lock
  settledOutcomeKey String? // outcome gagnant
  lockedAt          DateTime?
  settledAt         DateTime?

  pools MarketPool[]
  bets  MarketBet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([tournamentId])
  @@index([type])
  @@index([status])
}

model MarketPool {
  id         String        @id @default(uuid()) @db.Uuid
  marketId   String        @db.Uuid
  market     BettingMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcomeKey String // "2-1" / "OVER" / "<playerId>" / "<teamId>"
  totalPool  Int           @default(0)
  betCount   Int           @default(0)

  // Liens facultatifs pour faciliter les jointures UI
  playerId String? @db.Uuid
  teamId   String? @db.Uuid
  player   Player? @relation("MarketPoolPlayer", fields: [playerId], references: [id], onDelete: SetNull)
  team     Team?   @relation("MarketPoolTeam", fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([marketId, outcomeKey])
  @@index([marketId])
  @@index([playerId])
  @@index([teamId])
}

model MarketBet {
  id              String        @id @default(uuid()) @db.Uuid
  marketId        String        @db.Uuid
  market          BettingMarket @relation(fields: [marketId], references: [id], onDelete: Restrict)
  userId          String        @db.Uuid
  user            User          @relation("MarketBetUser", fields: [userId], references: [id], onDelete: Restrict)
  outcomeKey      String
  pointsWagered   Int
  oddsAtPlacement Decimal       @db.Decimal(7, 3)
  status          BetStatus     @default(PENDING)
  actualPayout    Int           @default(0)
  settledAt       DateTime?

  // Combiné — null si pari simple
  slipId String?  @db.Uuid
  slip   BetSlip? @relation(fields: [slipId], references: [id], onDelete: Cascade)

  wizebotDebitTxId   String?
  wizebotCreditTxId  String?
  wizebotCreditError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([marketId])
  @@index([status])
  @@index([slipId])
}

model BetSlip {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation("BetSlipUser", fields: [userId], references: [id], onDelete: Restrict)
  totalStake      Int
  combinedOdds    Decimal   @db.Decimal(10, 3) // produit des cotes des bets
  potentialPayout Int
  actualPayout    Int       @default(0)
  status          BetStatus @default(PENDING)
  settledAt       DateTime?

  wizebotDebitTxId  String?
  wizebotCreditTxId String?

  bets MarketBet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// =================== LIVE EVENTS ===================
//
// Chaque événement publié pendant un match (kick-off, but, carton, fin).
// Append-only : on ne modifie pas un event, on le supprime + en recrée si
// erreur de saisie. Ces events alimentent à la fois :
//  - le feed visible sur la page match
//  - les notifications toast pour les viewers (polling /events?since=...)
//  - le webhook outbound (MATCH_STARTED / MATCH_FINISHED) pour les intégrations

enum MatchEventType {
  MATCH_STARTED       // Coup d'envoi
  HALF_TIME           // Mi-temps
  SECOND_HALF         // Reprise 2e mi-temps
  MATCH_ENDED         // Coup de sifflet final
  GOAL                // But marqué
  OWN_GOAL            // But contre son camp
  PENALTY_SCORED      // Penalty marqué
  PENALTY_MISSED      // Penalty manqué
  YELLOW_CARD         // Carton jaune
  RED_CARD            // Carton rouge
  SUBSTITUTION        // Remplacement
  COMMENT             // Commentaire libre du speaker
}

model MatchEvent {
  id      String         @id @default(uuid()) @db.Uuid
  matchId String         @db.Uuid
  match   Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type    MatchEventType
  minute  Int? // minute du match (null pour MATCH_STARTED/MATCH_ENDED)

  // Équipe concernée (but, carton…). null pour les events neutres
  teamId String? @db.Uuid
  team   Team?   @relation("MatchEventTeam", fields: [teamId], references: [id], onDelete: SetNull)

  // Joueur concerné si applicable
  playerId String? @db.Uuid
  player   Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  description String? // Texte libre, ex "Penalty arrêté par le gardien"

  // Auteur (admin/coach qui a publié)
  createdById String? @db.Uuid

  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([matchId, createdAt])
  @@index([type])
}
